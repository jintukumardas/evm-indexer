{
  "name": "evm-event-indexer",
  "version": "0.1.0",
  "private": true,
  "author": "Jintu Kumar Das <jintukumardas@gmail.com>",
  "description": "Indexer for EVM contract events.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "sync": "tsx --env-file=.env src/jobs/syncIndexer.ts",
    "sync:built": "node --env-file-if-exists=.env dist/jobs/syncIndexer.js",
    "backfill": "tsx --env-file=.env src/scripts/backfill.ts",
    "e2e": "bash scripts/e2e/run.sh",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand tests/unit",
    "test:integration": "jest --runInBand tests/integration",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@typegoose/typegoose": "^11.7.1",
    "ethers": "^5.7.2",
    "express": "^4.19.2",
    "mongoose": "^7.6.10",
    "pino": "^8.21.0",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.2",
    "swagger-ui-express": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.8",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
