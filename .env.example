# --- Application ---
NODE_ENV=development
LOG_LEVEL=info

# --- API ---
API_ENABLED=true
API_PORT=3000

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/lifi_indexer

# ===========================================================
# Chain configuration
# ----------------------------------------------------------
# Each chain has its own ENV block. Polygon is required.
# Ethereum / Arbitrum are opt-in — set the _RPC_URL(S),
# _FEE_COLLECTOR_ADDRESS, and _START_BLOCK and they'll be
# registered automatically.
#
# Each chain accepts either a single _RPC_URL or a
# comma-separated _RPC_URLS list. When multiple URLs are
# provided a FallbackProvider is built across them.
# ===========================================================

# --- Polygon ---
POLYGON_RPC_URL=https://polygon-rpc.com
# POLYGON_RPC_URLS=https://polygon-rpc.com,https://rpc-mainnet.matic.network
POLYGON_FEE_COLLECTOR_ADDRESS=0xbD6C7B0d2f68c2b7805d88388319cfB6EcB50eA9
POLYGON_START_BLOCK=78600000
POLYGON_CONFIRMATIONS=12
POLYGON_CHUNK_SIZE=2000
POLYGON_MIN_CHUNK_SIZE=50
POLYGON_MAX_CHUNK_RETRIES=6
# 0 disables reorg reconciliation; values 20-100 are typical.
POLYGON_REORG_WINDOW=0

# --- Ethereum (optional) ---
# ETHEREUM_RPC_URL=
# ETHEREUM_FEE_COLLECTOR_ADDRESS=
# ETHEREUM_START_BLOCK=
# ETHEREUM_CONFIRMATIONS=20
# ETHEREUM_CHUNK_SIZE=2000
# ETHEREUM_MIN_CHUNK_SIZE=50
# ETHEREUM_MAX_CHUNK_RETRIES=6
# ETHEREUM_REORG_WINDOW=0

# --- Arbitrum (optional) ---
# ARBITRUM_RPC_URL=
# ARBITRUM_FEE_COLLECTOR_ADDRESS=
# ARBITRUM_START_BLOCK=
# ARBITRUM_CONFIRMATIONS=1
# ARBITRUM_CHUNK_SIZE=5000
# ARBITRUM_MIN_CHUNK_SIZE=100
# ARBITRUM_MAX_CHUNK_RETRIES=6
# ARBITRUM_REORG_WINDOW=0

# --- Sync loop behaviour ---
SYNC_RUN_ONCE=true
SYNC_INTERVAL_MS=15000

# --- RPC retry policy (transient errors) ---
RPC_RETRY_MAX_ATTEMPTS=5
RPC_RETRY_BASE_DELAY_MS=250
RPC_RETRY_MAX_DELAY_MS=10000

# --- Optional sub-passes ---
TOKEN_ENRICHMENT_ENABLED=true
AGGREGATES_ENABLED=true
